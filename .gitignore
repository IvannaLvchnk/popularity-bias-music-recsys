# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — do NOT commit raw LFM-1b or XITE files (too large; restricted licence)
data/raw/
data/mydata/
*.parquet
*.h5
*.hdf5
*.pkl
*.pickle

# But DO commit processed lightweight CSVs and result tables
!data/processed/*.csv
!results/*.csv
!results/*.json

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Figures (generated by notebooks)
fig*.png
fig*.pdf
